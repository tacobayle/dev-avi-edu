<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab 9: NSX Cloud - VLAN-backed use case</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
<br>
<br>
<h1>Lab 9: NSX Cloud - VLAN-backed use case</h1>
<h2>Commands</h2>
<table>
    <tr>
        <th class="centered-header">Task Number</th>
        <th class="centered-header">Step Number</th>
        <th class="centered-header">command</th>
        <th class="centered-header">Copy</th>
    </tr>
    <tr>
        <td>5</td>
        <td>1</td>
        <td><code><div id="contentToCopy0">shell<br></div></code></td>
        <td><button id="copyButton0">Copy</button></td>
    </tr>
    <tr>
        <td>5</td>
        <td>2</td>
        <td><code><div id="contentToCopy1">switchto cloud nsx-vlan-cloud<br>
            configure vrfcontext management<br>
            static_routes route_id 1 prefix 0.0.0.0/0 next_hop 192.168.151.1<br>
            save<br>
            save<br>
            exit<br>
        </div></code></td>
        <td><button id="copyButton1">Copy</button></td>
    </tr>
    <tr>
        <td>7</td>
        <td>5</td>
        <td><code><div id="contentToCopy2">curl -I http://nsx-vlan-vs.sb.vclass.local
        </div></code></td>
        <td><button id="copyButton2">Copy</button></td>
    </tr>
</table>
<br>
<br>
<script src="lab09.js"></script>
</body>
</html>